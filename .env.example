# DVexa AI 选股系统配置

# === LLM 配置 ===
# provider: deepseek / dashscope / openai
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_API_KEY=your_api_key_here
# 自定义端点（留空则自动根据 provider 设置）
LLM_BASE_URL=

# === 数据库 ===
DB_PATH=cache.db
MEMORY_DB_PATH=data/dvexa_memory.db

# === TradingAgents-CN ===
TA_DEPTH=3
TA_MARKET=A

# === 通知 ===
# channel: console / telegram / wechat
NOTIFY_CHANNEL=console
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WECHAT_WEBHOOK_URL=

# === 调度 ===
SCAN_HOUR=15
SCAN_MINUTE=30
